  "hypothesis_evaluations": [
    {
      "id": "H0",
      "claim": "T54 descent only works for empty-conflict FinaliEvent structures.",
      "status": "refuted",
      "evidence": "canonical_conflict_descent theorem_applies=True"
    },
    {
      "id": "H1",
      "claim": "Conflict can be added as an independent finite relation without changing T54.",
      "status": "partially_supported",
      "evidence": "Conflict is finite and independent, but T55 adds C8-C11 beyond T54."
    },
    {
      "id": "H2",
      "claim": "Conflict introduces new descent conditions beyond the T54 basis.",
      "status": "supported",
      "evidence": "upward_inheritance_failure is AM-valid and partial-order valid but conflict_invalid."
    },
    {
      "id": "H3",
      "claim": "Conflict forces full event-structure machinery beyond finite quotient-union checks.",
      "status": "refuted",
      "evidence": "The tested witness family is decided by finite conflict checks over the quotient-union."
    },
    {
      "id": "H4",
      "claim": "FinaliEvent order and conflict cannot be reconstructed from the same data.",
      "status": "supported",
      "evidence": "canonical_conflict_descent and same_order_no_conflict_control have the same record order and AM-valid axis profiles but different conflict relations."
    }
  ],
  "event_structure_verdict": "Full NPW event-structure machinery can still be postponed for the tested finite witness family. T55 needs an NPW-shaped conflict relation, but irreflexivity, comparable-conflict freedom, upward inheritance, and explicit disagreement checks are finite conflict checks decidable directly on the quotient-union completion.",
  "best_supported": "H2 supported and H0/H3 refuted: T54 generalizes to non-empty conflict, but only after adding explicit finite conflict-descent conditions. Conflict is not reducible to order or AM metadata in the tested cases."
}