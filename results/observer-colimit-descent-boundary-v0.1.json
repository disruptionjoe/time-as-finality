  "hypothesis_evaluations": [
    {
      "id": "H0",
      "claim": "T51/T52-style positive colimits cover all meaningful multi-observer merges.",
      "status": "refuted",
      "evidence": "Boundary cases include underdetermined identity, AM failure, repair, and non-definable overlap."
    },
    {
      "id": "H1",
      "claim": "Every compatible observer merge has a unique canonical event-finality completion.",
      "status": "refuted",
      "evidence": "ambiguous_event_identity unique=False"
    },
    {
      "id": "H2",
      "claim": "Partial-order validity can hold while uniqueness requires extra descent data.",
      "status": "supported",
      "evidence": "all compatible completions partial orders=True; ambiguous verdict=underdetermined_noncanonical"
    },
    {
      "id": "H3",
      "claim": "Record-order colimits can remain valid while finality-axis reconstruction fails.",
      "status": "supported",
      "evidence": "axis case verdict=valid_partial_order_axis_failure"
    },
    {
      "id": "H4",
      "claim": "Some boundary failures are hidden-record repairable; others remain noncanonical.",
      "status": "supported",
      "evidence": "repair verdict=repairable_by_hidden_record; identity verdict=underdetermined_noncanonical"
    },
    {
